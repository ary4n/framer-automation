# Required — Get your API key from Framer: Site Settings → API → Generate Key
FRAMER_API_KEY=your_framer_api_key_here
FRAMER_PROJECT_URL=https://your-project.framer.website

# Optional — For real keyword volume/CPC data (Step 2 of /seo-article)
# Get a key at https://keywordseverywhere.com/
KEYWORDS_EVERYWHERE_API_KEY=

# Optional — For Google Ads Keyword Planner data
# Requires a Google Ads account with API access
# See: https://developers.google.com/google-ads/api/docs/first-call/overview
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=
